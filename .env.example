# Local development only. Replace every placeholder before use.
DATABASE_URL=postgresql://noxroute:noxroute-local-dev@127.0.0.1:5433/noxrouteneo
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
APP_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
SETUP_TOKEN=replace-with-a-random-setup-token
APP_LOCALE=en
NOXROUTE_ADMIN_DOMAIN=localhost
NOXROUTE_VPN_DOMAIN=localhost

# Production Compose pulls these multi-architecture images by default.
NOXROUTE_IMAGE_REGISTRY=ghcr.io/drslid
NOXROUTE_IMAGE_TAG=main

# Optional low-memory defaults. Increase only after measuring real concurrency.
DATABASE_POOL_MAX=5
POSTGRES_MAX_CONNECTIONS=30
POSTGRES_SHARED_BUFFERS=32MB
POSTGRES_WORK_MEM=1MB
POSTGRES_MAINTENANCE_WORK_MEM=16MB
POSTGRES_EFFECTIVE_CACHE_SIZE=256MB
RUNTIME_DATABASE_POOL_MIN_SIZE=1
RUNTIME_DATABASE_POOL_MAX_SIZE=3
RUNTIME_POLL_SECONDS=5
RUNTIME_STATE_HEARTBEAT_SECONDS=15
