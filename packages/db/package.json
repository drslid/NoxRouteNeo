    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.10",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
